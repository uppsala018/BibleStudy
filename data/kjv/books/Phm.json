{"work":"KJV + Strong's","code":"Phm","book":"Philemon","chapterCount":1,"chapters":[{"number":1,"verses":[{"id":"Phm|1|1","reference":"Philemon 1:1","number":1,"text":"Paul, a prisoner of Jesus Christ, and Timothy <em>our</em> brother, unto Philemon our dearly beloved, and fellowlabourer,","strongs":[{"label":"Paul","strongsId":"G3972"},{"label":"a prisoner","strongsId":"G1198"},{"label":"of Jesus","strongsId":"G2424"},{"label":"Christ","strongsId":"G5547"},{"label":"and","strongsId":"G2532"},{"label":"Timothy","strongsId":"G5095"},{"label":"em>our</em> brother","strongsId":"G80"},{"label":"unto Philemon","strongsId":"G5371"},{"label":"our","strongsId":"G2257"},{"label":"dearly beloved","strongsId":"G27"},{"label":"and","strongsId":"G2532"}]},{"id":"Phl|1|1","reference":"Philemon 1:1","number":1,"text":"Paul and Timotheus, the servants of Jesus Christ, to all the saints in Christ Jesus which are at Philippi, with the bishops and deacons:","strongs":[{"label":"Paul","strongsId":"G3972"},{"label":"and","strongsId":"G2532"},{"label":"Timotheus","strongsId":"G5095"},{"label":"the servants","strongsId":"G1401"},{"label":"of Jesus","strongsId":"G2424"},{"label":"Christ","strongsId":"G5547"},{"label":"to all","strongsId":"G3956"},{"label":"the saints","strongsId":"G40"},{"label":"in","strongsId":"G1722"},{"label":"Christ","strongsId":"G5547"},{"label":"Jesus","strongsId":"G2424"},{"label":"which are","strongsId":"G5607"},{"label":"at","strongsId":"G1722"},{"label":"Philippi","strongsId":"G5375"},{"label":"with","strongsId":"G4862"},{"label":"the bishops","strongsId":"G1985"},{"label":"and","strongsId":"G2532"}]},{"id":"Phm|1|2","reference":"Philemon 1:2","number":2,"text":"And to <em>our</em> beloved Apphia, and Archippus our fellowsoldier, and to the church in thy house:","strongs":[{"label":"And","strongsId":"G2532"},{"label":"to <em>our</em> beloved","strongsId":"G27"},{"label":"Apphia","strongsId":"G682"},{"label":"and","strongsId":"G2532"},{"label":"Archippus","strongsId":"G751"},{"label":"our","strongsId":"G2257"},{"label":"fellowsoldier","strongsId":"G4961"},{"label":"and","strongsId":"G2532"},{"label":"to the church","strongsId":"G1577"},{"label":"in","strongsId":"G2596"},{"label":"thy","strongsId":"G4675"}]},{"id":"Phl|1|2","reference":"Philemon 1:2","number":2,"text":"Grace <em>be</em> unto you, and peace, from God our Father, and <em>from</em> the Lord Jesus Christ.","strongs":[{"label":"Grace","strongsId":"G5485"},{"label":"em>be</em> unto you","strongsId":"G5213"},{"label":"and","strongsId":"G2532"},{"label":"peace","strongsId":"G1515"},{"label":"from","strongsId":"G575"},{"label":"God","strongsId":"G2316"},{"label":"our","strongsId":"G2257"},{"label":"Father","strongsId":"G3962"},{"label":"and","strongsId":"G2532"},{"label":"em>from</em> the Lord","strongsId":"G2962"},{"label":"Jesus","strongsId":"G2424"}]},{"id":"Phm|1|3","reference":"Philemon 1:3","number":3,"text":"Grace to you, and peace, from God our Father and the Lord Jesus Christ.","strongs":[{"label":"Grace","strongsId":"G5485"},{"label":"to you","strongsId":"G5213"},{"label":"and","strongsId":"G2532"},{"label":"peace","strongsId":"G1515"},{"label":"from","strongsId":"G575"},{"label":"God","strongsId":"G2316"},{"label":"our","strongsId":"G2257"},{"label":"Father","strongsId":"G3962"},{"label":"and","strongsId":"G2532"},{"label":"the Lord","strongsId":"G2962"},{"label":"Jesus","strongsId":"G2424"}]},{"id":"Phl|1|3","reference":"Philemon 1:3","number":3,"text":"I thank my God upon every remembrance of you,","strongs":[{"label":"I thank","strongsId":"G2168"},{"label":"my","strongsId":"G3450"},{"label":"God","strongsId":"G2316"},{"label":"upon","strongsId":"G1909"},{"label":"every","strongsId":"G3956"},{"label":"remembrance","strongsId":"G3417"}]},{"id":"Phm|1|4","reference":"Philemon 1:4","number":4,"text":"I thank my God, making mention of thee always in my prayers,","strongs":[{"label":"I thank","strongsId":"G2168"},{"label":"my","strongsId":"G3450"},{"label":"God","strongsId":"G2316"},{"label":"making","strongsId":"G4160"},{"label":"mention","strongsId":"G3417"},{"label":"of thee","strongsId":"G4675"},{"label":"always","strongsId":"G3842"},{"label":"in","strongsId":"G1909"},{"label":"my","strongsId":"G3450"}]},{"id":"Phl|1|4","reference":"Philemon 1:4","number":4,"text":"Always in every prayer of mine for you all making request with joy,","strongs":[{"label":"Always","strongsId":"G3842"},{"label":"in","strongsId":"G1722"},{"label":"every","strongsId":"G3956"},{"label":"prayer","strongsId":"G1162"},{"label":"of mine","strongsId":"G3450"},{"label":"for","strongsId":"G5228"},{"label":"you","strongsId":"G5216"},{"label":"all","strongsId":"G3956"},{"label":"making","strongsId":"G4160"},{"label":"request","strongsId":"G1162"},{"label":"with","strongsId":"G3326"}]},{"id":"Phm|1|5","reference":"Philemon 1:5","number":5,"text":"Hearing of thy love and faith, which thou hast toward the Lord Jesus, and toward all saints;","strongs":[{"label":"Hearing","strongsId":"G191"},{"label":"of thy","strongsId":"G4675"},{"label":"love","strongsId":"G26"},{"label":"and","strongsId":"G2532"},{"label":"faith","strongsId":"G4102"},{"label":"which","strongsId":"G3739"},{"label":"thou hast","strongsId":"G2192"},{"label":"toward","strongsId":"G4314"},{"label":"the Lord","strongsId":"G2962"},{"label":"Jesus","strongsId":"G2424"},{"label":"and","strongsId":"G2532"},{"label":"toward","strongsId":"G1519"},{"label":"all","strongsId":"G3956"}]},{"id":"Phl|1|5","reference":"Philemon 1:5","number":5,"text":"For your fellowship in the gospel from the first day until now;","strongs":[{"label":"For","strongsId":"G1909"},{"label":"your","strongsId":"G5216"},{"label":"fellowship","strongsId":"G2842"},{"label":"in","strongsId":"G1519"},{"label":"the gospel","strongsId":"G2098"},{"label":"from","strongsId":"G575"},{"label":"the first","strongsId":"G4413"},{"label":"day","strongsId":"G2250"},{"label":"until","strongsId":"G891"}]},{"id":"Phm|1|6","reference":"Philemon 1:6","number":6,"text":"That the communication of thy faith may become effectual by the acknowledging of every good thing which is in you in Christ Jesus.","strongs":[{"label":"That","strongsId":"G3704"},{"label":"the communication","strongsId":"G2842"},{"label":"of thy","strongsId":"G4675"},{"label":"faith","strongsId":"G4102"},{"label":"may become","strongsId":"G1096"},{"label":"effectual","strongsId":"G1756"},{"label":"by","strongsId":"G1722"},{"label":"the acknowledging","strongsId":"G1922"},{"label":"of every","strongsId":"G3956"},{"label":"good thing","strongsId":"G18"},{"label":"which","strongsId":"G3588"},{"label":"is in","strongsId":"G1722"},{"label":"you","strongsId":"G5213"},{"label":"in","strongsId":"G1519"},{"label":"Christ","strongsId":"G5547"}]},{"id":"Phl|1|6","reference":"Philemon 1:6","number":6,"text":"Being confident of this very thing, that he which hath begun a good work in you will perform <em>it</em> until the day of Jesus Christ:","strongs":[{"label":"Being confident","strongsId":"G3982"},{"label":"of this","strongsId":"G5124"},{"label":"very thing","strongsId":"G846"},{"label":"that","strongsId":"G3754"},{"label":"he which hath begun","strongsId":"G1728"},{"label":"a good","strongsId":"G18"},{"label":"work","strongsId":"G2041"},{"label":"in","strongsId":"G1722"},{"label":"you","strongsId":"G5213"},{"label":"will perform","strongsId":"G2005"},{"label":"em>it</em> until","strongsId":"G891"},{"label":"the day","strongsId":"G2250"},{"label":"of Jesus","strongsId":"G2424"}]},{"id":"Phm|1|7","reference":"Philemon 1:7","number":7,"text":"For we have great joy and consolation in thy love, because the bowels of the saints are refreshed by thee, brother.","strongs":[{"label":"For","strongsId":"G1063"},{"label":"we have","strongsId":"G2192"},{"label":"great","strongsId":"G4183"},{"label":"joy","strongsId":"G5485"},{"label":"and","strongsId":"G2532"},{"label":"consolation","strongsId":"G3874"},{"label":"in","strongsId":"G1909"},{"label":"thy","strongsId":"G4675"},{"label":"love","strongsId":"G26"},{"label":"because","strongsId":"G3754"},{"label":"the bowels","strongsId":"G4698"},{"label":"of the saints","strongsId":"G40"},{"label":"are refreshed","strongsId":"G373"},{"label":"by","strongsId":"G1223"},{"label":"thee","strongsId":"G4675"}]},{"id":"Phl|1|7","reference":"Philemon 1:7","number":7,"text":"Even as it is meet for me to think this of you all, because I have you in my heart; inasmuch as both in my bonds, and in the defence and confirmation of the gospel, ye all are partakers of my grace.","strongs":[{"label":"Even as","strongsId":"G2531"},{"label":"it is","strongsId":"G2076"},{"label":"meet","strongsId":"G1342"},{"label":"for me","strongsId":"G1698"},{"label":"to think","strongsId":"G5426"},{"label":"this","strongsId":"G5124"},{"label":"of","strongsId":"G5228"},{"label":"you","strongsId":"G5216"},{"label":"all","strongsId":"G3956"},{"label":"because","strongsId":"G1223"},{"label":"I have","strongsId":"G2192"},{"label":"you","strongsId":"G5209"},{"label":"in","strongsId":"G1722"},{"label":"my","strongsId":"G3165"},{"label":"heart","strongsId":"G2588"},{"label":"inasmuch as both","strongsId":"G5037"},{"label":"in","strongsId":"G1722"},{"label":"my","strongsId":"G3450"},{"label":"bonds","strongsId":"G1199"},{"label":"and","strongsId":"G2532"},{"label":"in the defence","strongsId":"G627"},{"label":"and","strongsId":"G2532"},{"label":"confirmation","strongsId":"G951"},{"label":"of the gospel","strongsId":"G2098"},{"label":"ye","strongsId":"G5209"},{"label":"all","strongsId":"G3956"},{"label":"are","strongsId":"G5607"},{"label":"partakers","strongsId":"G4791"},{"label":"of my","strongsId":"G3450"}]},{"id":"Phm|1|8","reference":"Philemon 1:8","number":8,"text":"Wherefore, though I might be much bold in Christ to enjoin thee that which is convenient,","strongs":[{"label":"Wherefore","strongsId":"G1352"},{"label":"though I might be","strongsId":"G2192"},{"label":"much","strongsId":"G4183"},{"label":"bold","strongsId":"G3954"},{"label":"in","strongsId":"G1722"},{"label":"Christ","strongsId":"G5547"},{"label":"to enjoin","strongsId":"G2004"},{"label":"thee","strongsId":"G4671"}]},{"id":"Phl|1|8","reference":"Philemon 1:8","number":8,"text":"For God is my record, how greatly I long after you all in the bowels of Jesus Christ.","strongs":[{"label":"For","strongsId":"G1063"},{"label":"God","strongsId":"G2316"},{"label":"is","strongsId":"G2076"},{"label":"my","strongsId":"G3450"},{"label":"record","strongsId":"G3144"},{"label":"how","strongsId":"G5613"},{"label":"greatly I long after","strongsId":"G1971"},{"label":"you","strongsId":"G5209"},{"label":"all","strongsId":"G3956"},{"label":"in","strongsId":"G1722"},{"label":"the bowels","strongsId":"G4698"},{"label":"of Jesus","strongsId":"G2424"}]},{"id":"Phm|1|9","reference":"Philemon 1:9","number":9,"text":"Yet for love's sake I rather beseech <em>thee</em>, being such an one as Paul the aged, and now also a prisoner of Jesus Christ.","strongs":[{"label":"Yet for","strongsId":"G1223"},{"label":"love's","strongsId":"G26"},{"label":"sake I","strongsId":"G3870"},{"label":"rather","strongsId":"G3123"},{"label":"beseech","strongsId":"G3870"},{"label":"em>thee</em>, being","strongsId":"G5607"},{"label":"such an one","strongsId":"G5108"},{"label":"as","strongsId":"G5613"},{"label":"Paul","strongsId":"G3972"},{"label":"the aged","strongsId":"G4246"},{"label":"and","strongsId":"G1161"},{"label":"now","strongsId":"G3570"},{"label":"also","strongsId":"G2532"},{"label":"a prisoner","strongsId":"G1198"},{"label":"of Jesus","strongsId":"G2424"}]},{"id":"Phl|1|9","reference":"Philemon 1:9","number":9,"text":"And this I pray, that your love may abound yet more and more in knowledge and <em>in</em> all judgment;","strongs":[{"label":"And","strongsId":"G2532"},{"label":"this","strongsId":"G5124"},{"label":"I pray","strongsId":"G4336"},{"label":"that","strongsId":"G2443"},{"label":"your","strongsId":"G5216"},{"label":"love","strongsId":"G26"},{"label":"may abound","strongsId":"G4052"},{"label":"yet","strongsId":"G2089"},{"label":"more","strongsId":"G3123"},{"label":"and","strongsId":"G2532"},{"label":"more","strongsId":"G3123"},{"label":"in","strongsId":"G1722"},{"label":"knowledge","strongsId":"G1922"},{"label":"and","strongsId":"G2532"},{"label":"em>in</em> all","strongsId":"G3956"}]},{"id":"Phm|1|10","reference":"Philemon 1:10","number":10,"text":"I beseech thee for my son Onesimus, whom I have begotten in my bonds:","strongs":[{"label":"I beseech","strongsId":"G3870"},{"label":"thee","strongsId":"G4571"},{"label":"for","strongsId":"G4012"},{"label":"my","strongsId":"G1699"},{"label":"son","strongsId":"G5043"},{"label":"Onesimus","strongsId":"G3682"},{"label":"whom","strongsId":"G3739"},{"label":"I have begotten","strongsId":"G1080"},{"label":"in","strongsId":"G1722"},{"label":"my","strongsId":"G3450"}]},{"id":"Phl|1|10","reference":"Philemon 1:10","number":10,"text":"That ye may approve things that are excellent; that ye may be sincere and without offence till the day of Christ;","strongs":[{"label":"That","strongsId":"G1519"},{"label":"ye","strongsId":"G5209"},{"label":"may approve","strongsId":"G1381"},{"label":"things that are excellent","strongsId":"G1308"},{"label":"that","strongsId":"G2443"},{"label":"ye may be","strongsId":"G5600"},{"label":"sincere","strongsId":"G1506"},{"label":"and","strongsId":"G2532"},{"label":"without offence","strongsId":"G677"},{"label":"till","strongsId":"G1519"},{"label":"the day","strongsId":"G2250"}]},{"id":"Phm|1|11","reference":"Philemon 1:11","number":11,"text":"Which in time past was to thee unprofitable, but now profitable to thee and to me:","strongs":[{"label":"Which","strongsId":"G3588"},{"label":"in time past","strongsId":"G4218"},{"label":"was","strongsId":"G890"},{"label":"to thee","strongsId":"G4671"},{"label":"unprofitable","strongsId":"G890"},{"label":"but","strongsId":"G1161"},{"label":"now","strongsId":"G3570"},{"label":"profitable","strongsId":"G2173"},{"label":"to thee","strongsId":"G4671"},{"label":"and","strongsId":"G2532"}]},{"id":"Phl|1|11","reference":"Philemon 1:11","number":11,"text":"Being filled with the fruits of righteousness, which are by Jesus Christ, unto the glory and praise of God.","strongs":[{"label":"Being filled","strongsId":"G4137"},{"label":"with the fruits","strongsId":"G2590"},{"label":"of righteousness","strongsId":"G1343"},{"label":"which","strongsId":"G3588"},{"label":"are by","strongsId":"G1223"},{"label":"Jesus","strongsId":"G2424"},{"label":"Christ","strongsId":"G5547"},{"label":"unto","strongsId":"G1519"},{"label":"the glory","strongsId":"G1391"},{"label":"and","strongsId":"G2532"},{"label":"praise","strongsId":"G1868"}]},{"id":"Phm|1|12","reference":"Philemon 1:12","number":12,"text":"Whom I have sent again: thou therefore receive him, that is, mine own bowels:","strongs":[{"label":"Whom","strongsId":"G3739"},{"label":"I have sent again","strongsId":"G375"},{"label":"thou","strongsId":"G4771"},{"label":"therefore","strongsId":"G1161"},{"label":"receive","strongsId":"G4355"},{"label":"him","strongsId":"G846"},{"label":"that is","strongsId":"G5123"},{"label":"mine own","strongsId":"G1699"}]},{"id":"Phl|1|12","reference":"Philemon 1:12","number":12,"text":"But I would ye should understand, brethren, that the things <em>which happened</em> unto me have fallen out rather unto the furtherance of the gospel;","strongs":[{"label":"But","strongsId":"G1161"},{"label":"I would","strongsId":"G1014"},{"label":"ye","strongsId":"G5209"},{"label":"should understand","strongsId":"G1097"},{"label":"brethren","strongsId":"G80"},{"label":"that","strongsId":"G3754"},{"label":"the things <em>which happened</em> unto","strongsId":"G2596"},{"label":"me","strongsId":"G1691"},{"label":"have fallen out","strongsId":"G2064"},{"label":"rather","strongsId":"G3123"},{"label":"unto","strongsId":"G1519"},{"label":"the furtherance","strongsId":"G4297"}]},{"id":"Phm|1|13","reference":"Philemon 1:13","number":13,"text":"Whom I would have retained with me, that in thy stead he might have ministered unto me in the bonds of the gospel:","strongs":[{"label":"Whom","strongsId":"G3739"},{"label":"I","strongsId":"G1473"},{"label":"would","strongsId":"G1014"},{"label":"have retained","strongsId":"G2722"},{"label":"with","strongsId":"G4314"},{"label":"me","strongsId":"G1683"},{"label":"that","strongsId":"G2443"},{"label":"in thy","strongsId":"G4675"},{"label":"stead","strongsId":"G5228"},{"label":"he might have ministered","strongsId":"G1247"},{"label":"unto me","strongsId":"G3427"},{"label":"in","strongsId":"G1722"},{"label":"the bonds","strongsId":"G1199"}]},{"id":"Phl|1|13","reference":"Philemon 1:13","number":13,"text":"So that my bonds in Christ are manifest in all the palace, and in all other","strongs":[{"label":"So that","strongsId":"G5620"},{"label":"my","strongsId":"G3450"},{"label":"bonds","strongsId":"G1199"},{"label":"in","strongsId":"G1722"},{"label":"Christ","strongsId":"G5547"},{"label":"are","strongsId":"G1096"},{"label":"manifest","strongsId":"G5318"},{"label":"in","strongsId":"G1722"},{"label":"all","strongsId":"G3650"},{"label":"the palace","strongsId":"G4232"},{"label":"and","strongsId":"G2532"},{"label":"in all","strongsId":"G3956"}]},{"id":"Phm|1|14","reference":"Philemon 1:14","number":14,"text":"But without thy mind would I do nothing; that thy benefit should not be as it were of necessity, but willingly.","strongs":[{"label":"But","strongsId":"G1161"},{"label":"without","strongsId":"G5565"},{"label":"thy","strongsId":"G4674"},{"label":"mind","strongsId":"G1106"},{"label":"would","strongsId":"G2309"},{"label":"I do","strongsId":"G4160"},{"label":"nothing","strongsId":"G3762"},{"label":"that","strongsId":"G3363"},{"label":"thy","strongsId":"G4675"},{"label":"benefit","strongsId":"G18"},{"label":"should","strongsId":"G5600"},{"label":"not","strongsId":"G3363"},{"label":"be","strongsId":"G5600"},{"label":"as","strongsId":"G5613"},{"label":"it were of","strongsId":"G2596"},{"label":"necessity","strongsId":"G318"},{"label":"but","strongsId":"G235"},{"label":"willingly","strongsId":"G1595"}]},{"id":"Phl|1|14","reference":"Philemon 1:14","number":14,"text":"And many of the brethren in the Lord, waxing confident by my bonds, are much more bold to speak the word without fear.","strongs":[{"label":"And","strongsId":"G2532"},{"label":"many","strongsId":"G4119"},{"label":"of the brethren","strongsId":"G80"},{"label":"in","strongsId":"G1722"},{"label":"the Lord","strongsId":"G2962"},{"label":"waxing confident","strongsId":"G3982"},{"label":"by my","strongsId":"G3450"},{"label":"bonds","strongsId":"G1199"},{"label":"are much more","strongsId":"G4056"},{"label":"bold","strongsId":"G5111"},{"label":"to speak","strongsId":"G2980"},{"label":"the word","strongsId":"G3056"}]},{"id":"Phm|1|15","reference":"Philemon 1:15","number":15,"text":"For perhaps he therefore departed for a season, that thou shouldest receive him for ever;","strongs":[{"label":"For","strongsId":"G1063"},{"label":"For","strongsId":"G1223"},{"label":"perhaps","strongsId":"G5029"},{"label":"he","strongsId":"G5563"},{"label":"therefore","strongsId":"G5124"},{"label":"departed","strongsId":"G5563"},{"label":"for","strongsId":"G4314"},{"label":"a season","strongsId":"G5610"},{"label":"that","strongsId":"G2443"},{"label":"thou shouldest receive","strongsId":"G568"},{"label":"him","strongsId":"G846"}]},{"id":"Phl|1|15","reference":"Philemon 1:15","number":15,"text":"Some indeed preach Christ even of envy and strife; and some also of good will:","strongs":[{"label":"Some","strongsId":"G5100"},{"label":"indeed","strongsId":"G3303"},{"label":"preach","strongsId":"G2784"},{"label":"Christ","strongsId":"G5547"},{"label":"even","strongsId":"G2532"},{"label":"of","strongsId":"G1223"},{"label":"envy","strongsId":"G5355"},{"label":"and","strongsId":"G2532"},{"label":"strife","strongsId":"G2054"},{"label":"and","strongsId":"G1161"},{"label":"some","strongsId":"G5100"},{"label":"also","strongsId":"G2532"},{"label":"of","strongsId":"G1223"}]},{"id":"Phm|1|16","reference":"Philemon 1:16","number":16,"text":"Not now as a servant, but above a servant, a brother beloved, specially to me, but how much more unto thee, both in the flesh, and in the Lord?","strongs":[{"label":"Not now","strongsId":"G3765"},{"label":"as","strongsId":"G5613"},{"label":"a servant","strongsId":"G1401"},{"label":"but","strongsId":"G235"},{"label":"above","strongsId":"G5228"},{"label":"a servant","strongsId":"G1401"},{"label":"a brother","strongsId":"G80"},{"label":"beloved","strongsId":"G27"},{"label":"specially","strongsId":"G3122"},{"label":"to me","strongsId":"G1698"},{"label":"but","strongsId":"G1161"},{"label":"how much","strongsId":"G4214"},{"label":"more","strongsId":"G3123"},{"label":"unto thee","strongsId":"G4671"},{"label":"both","strongsId":"G2532"},{"label":"in","strongsId":"G1722"},{"label":"the flesh","strongsId":"G4561"},{"label":"and","strongsId":"G2532"},{"label":"in","strongsId":"G1722"}]},{"id":"Phl|1|16","reference":"Philemon 1:16","number":16,"text":"The one preach Christ of contention, not sincerely, supposing to add affliction to my bonds:","strongs":[{"label":"The one","strongsId":"G3303"},{"label":"preach","strongsId":"G2605"},{"label":"Christ","strongsId":"G5547"},{"label":"of","strongsId":"G1537"},{"label":"contention","strongsId":"G2052"},{"label":"not","strongsId":"G3756"},{"label":"sincerely","strongsId":"G55"},{"label":"supposing","strongsId":"G3633"},{"label":"to add","strongsId":"G2018"},{"label":"affliction","strongsId":"G2347"},{"label":"to my","strongsId":"G3450"}]},{"id":"Phm|1|17","reference":"Philemon 1:17","number":17,"text":"If thou count me therefore a partner, receive him as myself.","strongs":[{"label":"If","strongsId":"G1487"},{"label":"thou count","strongsId":"G2192"},{"label":"me","strongsId":"G1691"},{"label":"therefore","strongsId":"G3767"},{"label":"a partner","strongsId":"G2844"},{"label":"receive","strongsId":"G4355"},{"label":"him","strongsId":"G846"},{"label":"as","strongsId":"G5613"}]},{"id":"Phl|1|17","reference":"Philemon 1:17","number":17,"text":"But the other of love, knowing that I am set for the defence of the gospel.","strongs":[{"label":"But","strongsId":"G1161"},{"label":"the other of","strongsId":"G1537"},{"label":"love","strongsId":"G26"},{"label":"knowing","strongsId":"G1492"},{"label":"that","strongsId":"G3754"},{"label":"I am set","strongsId":"G2749"},{"label":"for","strongsId":"G1519"},{"label":"the defence","strongsId":"G627"}]},{"id":"Phm|1|18","reference":"Philemon 1:18","number":18,"text":"If he hath wronged thee, or oweth <em>thee</em> ought, put that on mine account;","strongs":[{"label":"If","strongsId":"G1161"},{"label":"If","strongsId":"G1487"},{"label":"he hath wronged","strongsId":"G91"},{"label":"thee","strongsId":"G4571"},{"label":"or","strongsId":"G2228"},{"label":"oweth","strongsId":"G3784"},{"label":"em>thee</em> ought","strongsId":"G5100"},{"label":"put","strongsId":"G1677"},{"label":"that","strongsId":"G5124"},{"label":"on","strongsId":"G1677"}]},{"id":"Phl|1|18","reference":"Philemon 1:18","number":18,"text":"What then? notwithstanding, every way, whether in pretence, or in truth, Christ is preached; and I therein do rejoice, yea, and will rejoice.","strongs":[{"label":"What","strongsId":"G5101"},{"label":"then","strongsId":"G1063"},{"label":"notwithstanding","strongsId":"G4133"},{"label":"every","strongsId":"G3956"},{"label":"way","strongsId":"G5158"},{"label":"whether","strongsId":"G1535"},{"label":"in pretence","strongsId":"G4392"},{"label":"or","strongsId":"G1535"},{"label":"in truth","strongsId":"G225"},{"label":"Christ","strongsId":"G5547"},{"label":"is preached","strongsId":"G2605"},{"label":"and","strongsId":"G2532"},{"label":"I","strongsId":"G5463"},{"label":"therein","strongsId":"G1722"},{"label":"therein","strongsId":"G5129"},{"label":"do rejoice","strongsId":"G5463"},{"label":"yea","strongsId":"G235"},{"label":"and","strongsId":"G2532"}]},{"id":"Phm|1|19","reference":"Philemon 1:19","number":19,"text":"I Paul have written <em>it</em> with mine own hand, I will repay <em>it</em>: albeit I do not say to thee how thou owest unto me even thine own self besides.","strongs":[{"label":"I","strongsId":"G1473"},{"label":"Paul","strongsId":"G3972"},{"label":"have written","strongsId":"G1125"},{"label":"em>it</em> with mine own","strongsId":"G1699"},{"label":"hand","strongsId":"G5495"},{"label":"I","strongsId":"G1473"},{"label":"will repay","strongsId":"G661"},{"label":"em>it</em>: albeit","strongsId":"G3363"},{"label":"I do","strongsId":"G3004"},{"label":"not","strongsId":"G3363"},{"label":"say","strongsId":"G3004"},{"label":"to thee","strongsId":"G4671"},{"label":"how","strongsId":"G3754"},{"label":"thou owest","strongsId":"G4359"},{"label":"unto me","strongsId":"G3427"},{"label":"even","strongsId":"G2532"},{"label":"thine own self","strongsId":"G4572"}]},{"id":"Phl|1|19","reference":"Philemon 1:19","number":19,"text":"For I know that this shall turn to my salvation through your prayer, and the supply of the Spirit of Jesus Christ,","strongs":[{"label":"For","strongsId":"G1063"},{"label":"I know","strongsId":"G1492"},{"label":"that","strongsId":"G3754"},{"label":"this","strongsId":"G5124"},{"label":"shall turn","strongsId":"G576"},{"label":"to","strongsId":"G1519"},{"label":"my","strongsId":"G3427"},{"label":"salvation","strongsId":"G4991"},{"label":"through","strongsId":"G1223"},{"label":"your","strongsId":"G5216"},{"label":"prayer","strongsId":"G1162"},{"label":"and","strongsId":"G2532"},{"label":"the supply","strongsId":"G2024"},{"label":"of the Spirit","strongsId":"G4151"},{"label":"of Jesus","strongsId":"G2424"}]},{"id":"Phm|1|20","reference":"Philemon 1:20","number":20,"text":"Yea, brother, let me have joy of thee in the Lord: refresh my bowels in the Lord.","strongs":[{"label":"Yea","strongsId":"G3483"},{"label":"brother","strongsId":"G80"},{"label":"let","strongsId":"G3685"},{"label":"me","strongsId":"G1473"},{"label":"have joy","strongsId":"G3685"},{"label":"of thee","strongsId":"G4675"},{"label":"in","strongsId":"G1722"},{"label":"the Lord","strongsId":"G2962"},{"label":"refresh","strongsId":"G373"},{"label":"my","strongsId":"G3450"},{"label":"bowels","strongsId":"G4698"},{"label":"in","strongsId":"G1722"}]},{"id":"Phl|1|20","reference":"Philemon 1:20","number":20,"text":"According to my earnest expectation and <em>my</em> hope, that in nothing I shall be ashamed, but <em>that</em> with all boldness, as always, <em>so</em> now also Christ shall be magnified in my body, whether <em>it be</em> by life, or by death.","strongs":[{"label":"According","strongsId":"G2596"},{"label":"to my","strongsId":"G3450"},{"label":"earnest expectation","strongsId":"G603"},{"label":"and","strongsId":"G2532"},{"label":"em>my</em> hope","strongsId":"G1680"},{"label":"that","strongsId":"G3754"},{"label":"in","strongsId":"G1722"},{"label":"nothing","strongsId":"G3762"},{"label":"I shall be ashamed","strongsId":"G153"},{"label":"but","strongsId":"G235"},{"label":"em>that</em> with","strongsId":"G1722"},{"label":"all","strongsId":"G3956"},{"label":"boldness","strongsId":"G3954"},{"label":"as","strongsId":"G5613"},{"label":"always","strongsId":"G3842"},{"label":"em>so</em> now","strongsId":"G3568"},{"label":"also","strongsId":"G2532"},{"label":"Christ","strongsId":"G5547"},{"label":"shall be magnified","strongsId":"G3170"},{"label":"in","strongsId":"G1722"},{"label":"my","strongsId":"G3450"},{"label":"body","strongsId":"G4983"},{"label":"whether","strongsId":"G1535"},{"label":"em>it be</em> by","strongsId":"G1223"},{"label":"life","strongsId":"G2222"},{"label":"or","strongsId":"G1535"},{"label":"by","strongsId":"G1223"}]},{"id":"Phm|1|21","reference":"Philemon 1:21","number":21,"text":"Having confidence in thy obedience I wrote unto thee, knowing that thou wilt also do more than I say.","strongs":[{"label":"Having confidence","strongsId":"G3982"},{"label":"in thy","strongsId":"G4675"},{"label":"obedience","strongsId":"G5218"},{"label":"I wrote","strongsId":"G1125"},{"label":"unto thee","strongsId":"G4671"},{"label":"knowing","strongsId":"G1492"},{"label":"that","strongsId":"G3754"},{"label":"thou wilt","strongsId":"G4160"},{"label":"also","strongsId":"G2532"},{"label":"do","strongsId":"G4160"},{"label":"more than","strongsId":"G3739"},{"label":"more than","strongsId":"G5228"}]},{"id":"Phl|1|21","reference":"Philemon 1:21","number":21,"text":"For to me to live <em>is</em> Christ, and to die <em>is</em> gain.","strongs":[{"label":"For","strongsId":"G1063"},{"label":"to me","strongsId":"G1698"},{"label":"to live","strongsId":"G2198"},{"label":"em>is</em> Christ","strongsId":"G5547"},{"label":"and","strongsId":"G2532"},{"label":"to die","strongsId":"G599"}]},{"id":"Phm|1|22","reference":"Philemon 1:22","number":22,"text":"But withal prepare me also a lodging: for I trust that through your prayers I shall be given unto you.","strongs":[{"label":"But","strongsId":"G1161"},{"label":"withal","strongsId":"G260"},{"label":"prepare","strongsId":"G2090"},{"label":"me","strongsId":"G3427"},{"label":"also","strongsId":"G2532"},{"label":"a lodging","strongsId":"G3578"},{"label":"for","strongsId":"G1063"},{"label":"I trust","strongsId":"G1679"},{"label":"that","strongsId":"G3754"},{"label":"through","strongsId":"G1223"},{"label":"your","strongsId":"G5216"},{"label":"prayers","strongsId":"G4335"},{"label":"I shall be given","strongsId":"G5483"}]},{"id":"Phl|1|22","reference":"Philemon 1:22","number":22,"text":"But if I live in the flesh, this <em>is</em> the fruit of my labour: yet what I shall choose I wot not.","strongs":[{"label":"But","strongsId":"G1161"},{"label":"if","strongsId":"G1487"},{"label":"I live","strongsId":"G2198"},{"label":"in","strongsId":"G1722"},{"label":"the flesh","strongsId":"G4561"},{"label":"this","strongsId":"G5124"},{"label":"em>is</em> the fruit","strongsId":"G2590"},{"label":"of my labour","strongsId":"G2041"},{"label":"of my labour","strongsId":"G3427"},{"label":"yet","strongsId":"G2532"},{"label":"what","strongsId":"G5101"},{"label":"I shall choose","strongsId":"G138"},{"label":"I wot","strongsId":"G1107"}]},{"id":"Phm|1|23","reference":"Philemon 1:23","number":23,"text":"There salute thee Epaphras, my fellowprisoner in Christ Jesus;","strongs":[{"label":"There salute","strongsId":"G782"},{"label":"thee","strongsId":"G4571"},{"label":"Epaphras","strongsId":"G1889"},{"label":"my","strongsId":"G3450"},{"label":"fellowprisoner","strongsId":"G4869"},{"label":"in","strongsId":"G1722"},{"label":"Christ","strongsId":"G5547"}]},{"id":"Phl|1|23","reference":"Philemon 1:23","number":23,"text":"For I am in a strait betwixt two, having a desire to depart, and to be with Christ; which is far better:","strongs":[{"label":"For","strongsId":"G1063"},{"label":"I am in a strait","strongsId":"G4912"},{"label":"betwixt","strongsId":"G1537"},{"label":"two","strongsId":"G1417"},{"label":"having","strongsId":"G2192"},{"label":"a desire","strongsId":"G1939"},{"label":"to","strongsId":"G1519"},{"label":"depart","strongsId":"G360"},{"label":"and","strongsId":"G2532"},{"label":"to be","strongsId":"G1511"},{"label":"with","strongsId":"G4862"},{"label":"Christ","strongsId":"G5547"},{"label":"which is far","strongsId":"G4183"},{"label":"which is far","strongsId":"G3123"}]},{"id":"Phm|1|24","reference":"Philemon 1:24","number":24,"text":"Marcus, Aristarchus, Demas, Lucas, my fellowlabourers.","strongs":[{"label":"Marcus","strongsId":"G3138"},{"label":"Aristarchus","strongsId":"G708"},{"label":"Demas","strongsId":"G1214"},{"label":"Lucas","strongsId":"G3065"},{"label":"my","strongsId":"G3450"}]},{"id":"Phl|1|24","reference":"Philemon 1:24","number":24,"text":"Nevertheless to abide in the flesh <em>is</em> more needful for you.","strongs":[{"label":"Nevertheless","strongsId":"G1161"},{"label":"to abide","strongsId":"G1961"},{"label":"in","strongsId":"G1722"},{"label":"the flesh","strongsId":"G4561"},{"label":"em>is</em> more needful","strongsId":"G316"},{"label":"for","strongsId":"G1223"}]},{"id":"Phm|1|25","reference":"Philemon 1:25","number":25,"text":"The grace of our Lord Jesus Christ <em>be</em> with your spirit. Amen.","strongs":[{"label":"The grace","strongsId":"G5485"},{"label":"of our","strongsId":"G2257"},{"label":"Lord","strongsId":"G2962"},{"label":"Jesus","strongsId":"G2424"},{"label":"Christ","strongsId":"G5547"},{"label":"em>be</em> with","strongsId":"G3326"},{"label":"your","strongsId":"G5216"},{"label":"spirit","strongsId":"G4151"}]},{"id":"Phl|1|25","reference":"Philemon 1:25","number":25,"text":"And having this confidence, I know that I shall abide and continue with you all for your furtherance and joy of faith;","strongs":[{"label":"And","strongsId":"G2532"},{"label":"having this","strongsId":"G5124"},{"label":"confidence","strongsId":"G3982"},{"label":"I know","strongsId":"G1492"},{"label":"that","strongsId":"G3754"},{"label":"I shall abide","strongsId":"G3306"},{"label":"and","strongsId":"G2532"},{"label":"continue","strongsId":"G4839"},{"label":"with you","strongsId":"G5213"},{"label":"all","strongsId":"G3956"},{"label":"for","strongsId":"G1519"},{"label":"your","strongsId":"G5216"},{"label":"furtherance","strongsId":"G4297"},{"label":"and","strongsId":"G2532"},{"label":"joy","strongsId":"G5479"}]},{"id":"Phl|1|26","reference":"Philemon 1:26","number":26,"text":"That your rejoicing may be more abundant in Jesus Christ for me by my coming to you again.","strongs":[{"label":"That","strongsId":"G2443"},{"label":"your","strongsId":"G5216"},{"label":"rejoicing","strongsId":"G2745"},{"label":"may be more abundant","strongsId":"G4052"},{"label":"in","strongsId":"G1722"},{"label":"Jesus","strongsId":"G2424"},{"label":"Christ","strongsId":"G5547"},{"label":"for","strongsId":"G1722"},{"label":"me","strongsId":"G1698"},{"label":"by","strongsId":"G1223"},{"label":"my","strongsId":"G1699"},{"label":"coming","strongsId":"G3952"},{"label":"to","strongsId":"G4314"},{"label":"you","strongsId":"G5209"}]},{"id":"Phl|1|27","reference":"Philemon 1:27","number":27,"text":"Only let your conversation be as it becometh the gospel of Christ: that whether I come and see you, or else be absent, I may hear of your affairs, that ye stand fast in one spirit, with one mind striving together for the faith of the gospel;","strongs":[{"label":"Only","strongsId":"G3440"},{"label":"let your conversation be","strongsId":"G4176"},{"label":"as it becometh","strongsId":"G516"},{"label":"the gospel","strongsId":"G2098"},{"label":"of Christ","strongsId":"G5547"},{"label":"that","strongsId":"G2443"},{"label":"whether","strongsId":"G1535"},{"label":"I come","strongsId":"G2064"},{"label":"and","strongsId":"G2532"},{"label":"see","strongsId":"G1492"},{"label":"you","strongsId":"G5209"},{"label":"or","strongsId":"G1535"},{"label":"else be absent","strongsId":"G548"},{"label":"I may hear","strongsId":"G191"},{"label":"of your","strongsId":"G5216"},{"label":"affairs","strongsId":"G4012"},{"label":"that","strongsId":"G3754"},{"label":"ye stand fast","strongsId":"G4739"},{"label":"in","strongsId":"G1722"},{"label":"one","strongsId":"G1520"},{"label":"spirit","strongsId":"G4151"},{"label":"with one","strongsId":"G3391"},{"label":"mind","strongsId":"G5590"},{"label":"striving together","strongsId":"G4866"},{"label":"for the faith","strongsId":"G4102"}]},{"id":"Phl|1|28","reference":"Philemon 1:28","number":28,"text":"And in nothing terrified by your adversaries: which is to them an evident token of perdition, but to you of salvation, and that of God.","strongs":[{"label":"And","strongsId":"G2532"},{"label":"in","strongsId":"G1722"},{"label":"nothing","strongsId":"G3367"},{"label":"nothing","strongsId":"G3361"},{"label":"terrified","strongsId":"G4426"},{"label":"by","strongsId":"G5259"},{"label":"your adversaries","strongsId":"G480"},{"label":"which","strongsId":"G3748"},{"label":"is","strongsId":"G2076"},{"label":"to them","strongsId":"G846"},{"label":"to them","strongsId":"G3303"},{"label":"an evident token","strongsId":"G1732"},{"label":"of perdition","strongsId":"G684"},{"label":"but","strongsId":"G1161"},{"label":"to you","strongsId":"G5213"},{"label":"of salvation","strongsId":"G4991"},{"label":"and","strongsId":"G2532"},{"label":"that","strongsId":"G5124"},{"label":"of","strongsId":"G575"}]},{"id":"Phl|1|29","reference":"Philemon 1:29","number":29,"text":"For unto you it is given in the behalf of Christ, not only to believe on him, but also to suffer for his sake;","strongs":[{"label":"For","strongsId":"G3754"},{"label":"unto you","strongsId":"G5213"},{"label":"it is given","strongsId":"G5483"},{"label":"in the behalf","strongsId":"G5228"},{"label":"of Christ","strongsId":"G5547"},{"label":"not","strongsId":"G3756"},{"label":"only","strongsId":"G3440"},{"label":"to believe","strongsId":"G4100"},{"label":"on","strongsId":"G1519"},{"label":"him","strongsId":"G846"},{"label":"but","strongsId":"G235"},{"label":"also","strongsId":"G2532"},{"label":"to suffer","strongsId":"G3958"},{"label":"for","strongsId":"G5228"},{"label":"his sake","strongsId":"G846"}]},{"id":"Phl|1|30","reference":"Philemon 1:30","number":30,"text":"Having the same conflict which ye saw in me, and now hear <em>to be</em> in me.","strongs":[{"label":"Having","strongsId":"G2192"},{"label":"the same","strongsId":"G846"},{"label":"conflict","strongsId":"G73"},{"label":"which","strongsId":"G3634"},{"label":"ye saw","strongsId":"G1492"},{"label":"in","strongsId":"G1722"},{"label":"me","strongsId":"G1698"},{"label":"and","strongsId":"G2532"},{"label":"now","strongsId":"G3568"},{"label":"hear","strongsId":"G191"},{"label":"em>to be</em> in","strongsId":"G1722"}]}]}]}
